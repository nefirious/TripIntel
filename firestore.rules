rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: searches
    // Document ID: normalized city name
    // Fields:
    //   - city: string (required) - original display name
    //   - count: number (required) - search count
    //   - lastSearched: timestamp (optional) - last search time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sabernewfoundland@gmail.com" && request.auth.token.email_verified == true));
    }

    // Searches Collection Rules
    match /searches/{cityId} {
      // Allow anyone to read search counts
      allow read: if true;
      
      // Allow anyone to increment search count
      allow create: if request.resource.data.keys().hasAll(['city', 'count']) &&
                      request.resource.data.city is string &&
                      request.resource.data.count == 1;
                      
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'lastSearched']) &&
                      request.resource.data.count == resource.data.count + 1;
                      
      // Only admins can delete or perform other updates
      allow delete: if isAdmin();
    }
  }
}
