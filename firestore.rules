rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: searches
    // Document ID: normalized city name
    // Fields:
    //   - city: string (required) - original display name
    //   - count: number (required) - search count
    //   - lastSearched: timestamp (optional) - last search time
    //
    // Collection: relief_locations
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - type: string (required) - enum: public, business, etc.
    //   - isAccessible: boolean (optional)
    //   - hasBabyChanging: boolean (optional)
    //   - isGenderNeutral: boolean (optional)
    //   - addedBy: string (optional) - user uid
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sabernewfoundland@gmail.com" && request.auth.token.email_verified == true));
    }

    // Searches Collection Rules
    match /searches/{cityId} {
      // Allow anyone to read search counts
      allow read: if true;
      
      // Allow anyone to increment search count
      allow create: if request.resource.data.keys().hasAll(['city', 'count']) &&
                      request.resource.data.city is string &&
                      request.resource.data.count == 1;
                      
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'lastSearched']) &&
                      request.resource.data.count == resource.data.count + 1;
                      
      // Only admins can delete or perform other updates
      allow delete: if isAdmin();
    }

    // Relief Locations Collection Rules
    match /relief_locations/{locationId} {
      function isValidReliefLocation(data) {
        return data.keys().hasAll(['name', 'lat', 'lng', 'type', 'addedBy']) &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.lat is number && data.lat >= -90 && data.lat <= 90 &&
               data.lng is number && data.lng >= -180 && data.lng <= 180 &&
               data.type in ['public', 'business', 'department_store', 'cafe', 'library', 'gas_station'];
      }

      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      isValidReliefLocation(request.resource.data) &&
                      request.resource.data.addedBy == request.auth.uid;
                      
      allow update: if isAuthenticated() && 
                      isValidReliefLocation(request.resource.data) &&
                      resource.data.addedBy == request.auth.uid &&
                      request.resource.data.addedBy == request.auth.uid;
                      
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.addedBy == request.auth.uid);
    }
  }
}
